{
  "name": "@volta-oss/content-calendar-compass",
  "version": "3.0.0",
  "private": false,
  "type": "module",
  "description": "A local-business content calendar that starts from real events, inventory, seasons, and community moments.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.js",
    "start": "python3 -m http.server 4173",
    "validate": "npm test",
    "certify": "npm run build && node --test test/v3.test.js",
    "test:all": "npm test",
    "test:python": "PYTHONPATH=backend/python python3 -m unittest discover -s backend/python/tests",
    "test:backend": "npm run test:python",
    "clean": "rm -f src/*.js src/*.js.map src/*.d.ts test/*.js test/*.js.map test/*.d.ts",
    "ci": "npm ci && npm test && npm run test:backend --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "docker:build": "docker build -t volta-oss/content-calendar-compass:local .",
    "docker:run": "docker compose up --build",
    "serve:python": "PYTHONPATH=backend/python python3 -m content_calendar_compass_backend.server"
  },
  "keywords": [
    "digital-equity",
    "local-first",
    "marketing-content",
    "oss",
    "release",
    "volta"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/volta-npo/content-calendar-compass.git"
  },
  "homepage": "https://volta-npo.github.io/content-calendar-compass/",
  "bugs": {
    "url": "https://github.com/volta-npo/content-calendar-compass/issues"
  },
  "author": "Volta Open Source <volta.npo@gmail.com>",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0"
  }
}
